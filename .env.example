# =============================================
# AI Interview Arena - 환경 변수 설정
# 사용법: 이 파일을 .env로 복사 후 API 키 입력
#   cp .env.example .env  (Mac/Linux)
#   Copy-Item .env.example .env  (Windows)
# =============================================

# ── 제공사 선택 ───────────────────────────────
# openai / gemini / anthropic 중 하나를 선택하세요.
LLM_PROVIDER=openai

# ── API 키 (사용할 제공사 키만 입력해도 되고, 전부 입력해도 됩니다) ──
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── 모델명 (LLM_PROVIDER 변경 시 함께 수정) ──────
# [OpenAI 사용 시]
COMPETITOR_LLM_MODEL=gpt-4o-mini
INTERVIEWER_LLM_MODEL=gpt-4o-mini
JUDGE_LLM_MODEL=gpt-4o

# [Gemini 사용 시 아래 세 줄로 교체]
# COMPETITOR_LLM_MODEL=gemini-1.5-flash
# INTERVIEWER_LLM_MODEL=gemini-1.5-flash
# JUDGE_LLM_MODEL=gemini-1.5-pro

# [Anthropic 사용 시 아래 세 줄로 교체]
# COMPETITOR_LLM_MODEL=claude-haiku-4-5-20251001
# INTERVIEWER_LLM_MODEL=claude-haiku-4-5-20251001
# JUDGE_LLM_MODEL=claude-sonnet-4-6

# ── 공통 LLM 파라미터 ─────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# ── 앱 설정 ──────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── PostgreSQL (평가팀 DB 연동 시 사용) ────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/interview_db

# ── Vector DB (데이터셋팀 RAG 연동 시 활성화) ───
# PINECONE_API_KEY=...
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
