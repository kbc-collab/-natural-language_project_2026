# =============================================
# LLM Agent 설계 파트 환경 변수 설정
# .env.example → .env 로 복사 후 값 채우기
# =============================================

# OpenAI API (LLM 호출용)
OPENAI_API_KEY=sk-...

# 앱 설정
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# PostgreSQL (평가팀 DB 연동 시 사용)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/interview_db

# Vector DB (데이터셋팀 RAG 연동 시 활성화)
# PINECONE_API_KEY=...
# PINECONE_ENV=...
# CHROMA_HOST=localhost
# CHROMA_PORT=8001

# 에이전트 설정
COMPETITOR_LLM_MODEL=gpt-4o-mini
JUDGE_LLM_MODEL=gpt-4o
INTERVIEWER_LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
